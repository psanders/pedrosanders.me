          ],
          "children": [
            {
              "type": "text",
              "id": "cn7IJ",
              "name": "Eyebrow",
              "fill": "#053204ff",
              "content": "02 / WHAT IT IS",
              "fontFamily": "Roboto Mono",
              "fontSize": 12,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "UcKJp",
              "name": "Title",
              "fill": "#053204ff",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "In your Slack, in your architecture reviews, in the room when the hard decisions get made.",
              "lineHeight": 1.15,
              "fontFamily": "Poppins",
              "fontSize": 26,
              "fontWeight": "700",
              "letterSpacing": -0.6
            },
            {
              "type": "text",
              "id": "sLMUj",
              "name": "Body",
              "fill": "#3a4a3a",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A fixed-scope engagement where I embed with your team. I set direction, pressure-test your plan, and keep you out of the ditches I've already driven into. Your team builds. My job is to make sure they build the right thing, in the right order, without the six-month detours.",
              "lineHeight": 1.55,
              "fontFamily": "Poppins",
              "fontSize": 15,
              "fontWeight": "500"
            }
          ]
        },
