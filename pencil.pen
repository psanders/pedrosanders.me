              "letterSpacing": 1.4
            },
            {
              "type": "text",
              "id": "r1eTIx",
              "x": 100,
              "y": 1050,
              "name": "type1",
              "fill": "#053204ff",
              "textGrowth": "fixed-width",
              "width": 980,
              "content": "Poppins for conviction. Roboto Mono for proof.",
              "lineHeight": 1.15,
              "fontFamily": "Poppins",
              "fontSize": 42,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "CNL7z",
              "x": 100,
              "y": 1170,
              "name": "type2",
              "fill": "#555555ff",
              "textGrowth": "fixed-width",
              "width": 980,
              "content": "Use large, plain statements. Avoid motivational fluff. Let technical clarity carry the confidence.",
              "lineHeight": 1.35,
              "fontFamily": "Poppins",
              "fontSize": 22,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "qL5sT",
              "x": 100,
              "y": 1320,
              "name": "sec23",
              "fill": "#053204ff",
              "content": "CONTENT LANES",
              "fontFamily": "Roboto Mono",
              "fontSize": 24,
              "fontWeight": "500",
              "letterSpacing": 1.4
            },
            {
              "type": "text",
              "id": "YGnFN",
              "x": 100,
              "y": 1385,
              "name": "lane1",
              "fill": "#053204ff",
              "textGrowth": "fixed-width",
              "width": 1120,
              "content": "01 Build notes: lessons from shipping infrastructure.\n02 Founder POV: why communications is changing.\n03 Operator advice: go-to-market, support, latency, trust.\n04 Open-source signal: community, changelog, product philosophy.",
              "lineHeight": 1.45,
              "fontFamily": "Poppins",
              "fontSize": 26,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "O9kai",
              "x": 100,
              "y": 1655,
              "name": "sec24",
              "fill": "#053204ff",
              "content": "DO / AVOID",
              "fontFamily": "Roboto Mono",
              "fontSize": 24,
              "fontWeight": "500",
              "letterSpacing": 1.4
            },
            {
              "type": "text",
              "id": "WTiby",
              "x": 100,
              "y": 1715,
              "name": "doText",
              "fill": "#053204ff",
              "textGrowth": "fixed-width",
              "width": 1120,
              "content": "Do: specific claims, concrete examples, plain endings.\nAvoid: hype, generic AI language, founder mystique, soft slogans.",
              "lineHeight": 1.35,
              "fontFamily": "Poppins",
              "fontSize": 24,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "PmOYb",
              "x": 100,
              "y": 715,
              "name": "terLabel",
              "fill": "#27150cff",
              "content": "TERTIARY ACCENTS",
              "fontFamily": "Roboto Mono",
              "fontSize": 20,
              "fontWeight": "500",
              "letterSpacing": 1.2
            },
            {
              "type": "text",
              "id": "I1mQz",
              "x": 100,
              "y": 755,
              "name": "terNote",
              "fill": "#555555ff",
              "textGrowth": "fixed-width",
              "width": 1040,
              "content": "Use sparingly for rule lines, small tags, buttons, pull quotes, and warm emphasis. Never as the main hero field.",
              "lineHeight": 1.35,
              "fontFamily": "Poppins",
              "fontSize": 18,
              "fontWeight": "500"
            },
