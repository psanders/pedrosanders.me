              "type": "text",
              "id": "o03P8",
              "name": "Lead",
              "fill": "#ffffffff",
              "textGrowth": "fixed-width",
              "width": 820,
              "content": "You've got a voice product to ship — or one that's starting to crack at scale. And the stack underneath is a maze.",
              "lineHeight": 1.22,
              "fontFamily": "Poppins",
              "fontSize": 34,
              "fontWeight": "700",
