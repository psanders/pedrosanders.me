          ],
          "children": [
            {
              "type": "text",
              "id": "jmziQ",
              "name": "Eyebrow",
              "fill": "#053204ff",
              "content": "01 / THE PROBLEM",
              "fontFamily": "Roboto Mono",
              "fontSize": 12,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "hOwcW",
              "name": "Lead",
              "fill": "#053204ff",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Some builds you can't iterate your way out of.",
              "lineHeight": 1.12,
              "fontFamily": "Poppins",
              "fontSize": 28,
              "fontWeight": "700",
              "letterSpacing": -0.6
            },
            {
              "type": "text",
              "id": "g1h4W",
              "name": "Para",
              "fill": "#3a4a3a",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "You're betting real money — maybe the company — on voice. The architecture decisions are close to irreversible. And your team is shipping at a layer they've never shipped at before.",
              "lineHeight": 1.55,
              "fontFamily": "Poppins",
              "fontSize": 15,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "hfyEg",
              "name": "Para",
              "fill": "#3a4a3a",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "You don't want a contractor who learns on your dime. You want the person who's already run this stack at millions of calls a day, in the room for the calls that matter.",
              "lineHeight": 1.55,
              "fontFamily": "Poppins",
              "fontSize": 15,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "CQyxA",
          "name": "What It Is",
          "width": "fill_container",
          "fill": "#e6fff5ff",
          "layout": "vertical",
          "gap": 16,
          "padding": [
