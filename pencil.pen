              "name": "Eyebrow",
              "fill": "#39e19eff",
              "content": "01 / THE PROBLEM",
              "fontFamily": "Roboto Mono",
              "fontSize": 12,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "Y2yoY",
              "name": "Lead",
              "fill": "#ffffffff",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "You've got a voice product to ship — and the stack underneath is a maze.",
              "lineHeight": 1.2,
              "fontFamily": "Poppins",
              "fontSize": 26,
              "fontWeight": "700",
              "letterSpacing": -0.6
            },
            {
              "type": "text",
              "id": "l4EM4",
              "name": "Para",
              "fill": "#a8c8a8",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "SIP, media, carriers, ASR, TTS, orchestration, and a dozen telephony edge cases nobody warned you about. Every architecture decision feels like it could cost you six months. Build or buy? Self-host or managed? Where do the calls actually break at 10x?",
              "lineHeight": 1.55,
              "fontFamily": "Poppins",
              "fontSize": 15,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "c1dso",
              "name": "Para",
              "fill": "#a8c8a8",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "You don't need another sales pitch. You need a map drawn by someone who's already been on the other end of a 3 AM crash.",
              "lineHeight": 1.55,
              "fontFamily": "Poppins",
              "fontSize": 15,
              "fontWeight": "500"
            }
          ]
        },
