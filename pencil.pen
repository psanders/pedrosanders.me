                  "width": "fill_container",
                  "descendants": {
                    "bwRS4": {
                      "content": "What if we need more than three sessions?"
                    },
                    "fHsmD": {
                      "content": "Some do. If it's clear you need ongoing help, the Roadmap rolls naturally into an Embed, and the $1,200 is credited toward it."
                    }
